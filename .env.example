# loupe configuration. Copy to .env (gitignored) and fill in as needed — all optional.

# Build/refresh path only (scripts/prefetch.ts, scripts/verify-*). A free openFDA key
# lifts the keyless 1000/day shared-IP cap to 120k/day. SERVER-SIDE ONLY — never a VITE_ var.
# Get one at https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# SPA → API base. Empty = same-origin (the default; the API serves the SPA). Set to an
# absolute origin only if the API is hosted separately from the SPA.
VITE_LOUPE_API=

# Absolute app origin used in copy-as-API snippets + deep-links. Defaults to https://loupe.health
VITE_LOUPE_APP=

# API server port (src/api/server.ts). Defaults to 8787.
PORT=8787
