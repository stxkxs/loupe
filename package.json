    "@tanstack/react-router": "^1.170.16",
    "clsx": "^2.1.1",
    "echarts": "^6.1.0",
    "hono": "^4.12.27",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
